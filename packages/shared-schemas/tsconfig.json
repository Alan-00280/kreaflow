{
  "extends": "@kreaflow/ts-config/base.json",
  "compilerOptions": {
    // "ignoreDeprecations": "6.0",
    "noEmit": false,        /* Dipaksa false agar folder dist mau diproduksi */
    "declaration": true,    /* Menghasilkan file cetakan .d.ts untuk autocomplete */
    "declarationMap": true, /* Menghubungkan klik definisi ke source code asli */
    "outDir": "./dist",     /* Lokasi folder muntahan hasil compile */
    "rootDir": "./src",      /* Lokasi folder kode mentah kamu */
    "strictNullChecks": true,
  },
  "include": ["src/**/*", "src"],
  "exclude": ["node_modules", "dist"]
}