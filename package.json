{
    "name": "kreaflow-monorepo",
    "private": true,
    "packageManager": "pnpm@10.33.0",
    "engines": {
        "node": "24.x",
        "pnpm": ">=9.0.0"
    },
    "scripts": {
        "dev": "turbo run dev --filter=!.",
        "build": "turbo run build --filter=!.",
        "lint": "turbo run lint --filter=!.",
        "format": "biome format --write .",
        "prepare": "husky"
    },
    "dependencies": {
        "hono": "^4.12.12",
        "pg": "^8.20.0",
        "pino": "^10.3.1",
        "pino-http": "^11.0.0"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.11",
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0",
        "pino-pretty": "^13.1.3",
        "turbo": "^2.0.0"
    },
    "lint-staged": {
        "*.{js,ts,tsx,json}": [
            "biome check --write --no-errors-on-unmatched"
        ]
    }
}