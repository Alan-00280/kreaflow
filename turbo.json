{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "prisma:generate": {
      "cache": true,
      "inputs": ["prisma/schema.prisma"],
      "outputs": ["../../node_modules/.prisma/client/**"]
    },
    "build": {
      "dependsOn": ["^build", "prisma:generate"],
      "outputs": [".next/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["prisma:generate"]
    },
    "lint": {
      "cache": true,
      "outputs": []
    }
  }
}