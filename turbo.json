{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "prisma:generate": {
      "cache": true,
      "inputs": ["prisma/schema.prisma"],
      "outputs": ["../../node_modules/.prisma/client/**"]
    },
    "build": {
      "dependsOn": ["^build", "prisma:generate"],
      "outputs": [".next/**", "dist/**"],
      "env": [
          "POSTGRES_PASSWORD_LOCAL", "DATABASE_URL", "ADMIN_EMAIL", "ADMIN_USER_PASSWORD", "OPERATOR_EMAIL", "OPERATOR_USER_PASSWORD", "JWT_SECRET", "JWT_REFRESH_SECRET", "FRONTEND_URL"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["prisma:generate"]
    },
    "lint": {
      "cache": true,
      "outputs": []
    }
  }
}